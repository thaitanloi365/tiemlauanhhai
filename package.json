    "dev": "next dev",
    "migrate:safe": "if [ -z \"$SUPABASE_DB_URL\" ]; then echo \"SUPABASE_DB_URL is missing\"; exit 1; fi; case \"$SUPABASE_DB_URL\" in postgres://*|postgresql://*) ;; *) echo \"SUPABASE_DB_URL must start with postgres:// or postgresql://\"; exit 1;; esac; case \"$SUPABASE_DB_URL\" in *\"[YOUR-PASSWORD]\"*|*\"<password>\"*|*\"xxxxxx\"*|*\"YOUR_PASSWORD\"*) echo \"SUPABASE_DB_URL still contains a placeholder password\"; exit 1;; esac; npx supabase@latest db push --db-url \"$SUPABASE_DB_URL\"",
    "migrate:remote": "npm run migrate:safe",
    "build": "next build",
    "start": "next start",
    "seed:admin": "bun seed-super-admin.mjs",
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "lint": "eslint . --quiet",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
